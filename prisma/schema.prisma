generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  fundraisers Fundraiser[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Fundraiser {
  id String @id @default(cuid())

  userId String?

  slug     String @unique
  title    String
  story    String
  category String

  goalAmount   Float
  amountRaised Float @default(0)

  surveySupporters Int @default(0)
  cashDonations    Int @default(0)

  views Int @default(0)

  coverImage String?

  status String @default("ACTIVE")

  user User? @relation(fields: [userId], references: [id])

  surveyCompletions SurveyCompletion[]

  surveySessions SurveySession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SurveyCompletion {
  id String @id @default(cuid())

  fundraiserId String

  userId String?

  provider String @default("CPX Research")

  transactionId String? @unique

  rewardAmount Float @default(0)

  status String @default("STARTED")

  startedAt DateTime @default(now())

  completedAt DateTime?

  fundraiser Fundraiser @relation(fields: [fundraiserId], references: [id], onDelete: Cascade)
}

model SurveySession {
  id String @id @default(cuid())

  fundraiserId String

  userId String?

  status String @default("STARTED")

  provider String @default("CPX Research")

  startedAt DateTime @default(now())

  completedAt DateTime?
  referrer    String?   @default("Direct")

  utmSource String?

  utmMedium String?

  utmCampaign String?

  fundraiser Fundraiser @relation(fields: [fundraiserId], references: [id], onDelete: Cascade)
}

model Consent {
  id String @id @default(cuid())
  userId String?
  email String?
  purpose String
  value Boolean @default(true)
  ip String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
