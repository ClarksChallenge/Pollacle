generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Fundraiser {
  id                String   @id @default(cuid())

  slug              String   @unique

  title             String
  story             String
  category          String

  goalAmount        Float
  amountRaised      Float    @default(0)

  surveySupporters  Int      @default(0)
  cashDonations     Int      @default(0)

  coverImage        String?

  status            String   @default("ACTIVE")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
