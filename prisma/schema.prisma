generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Fundraiser {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String   @db.VarChar(100)
  story             String   @db.VarChar(5000)
  category          String
  coverImage        String?
  goalAmount        Float
  amountRaised      Float    @default(0)
  surveySupporters  Int      @default(0)
  cashDonations     Int      @default(0)
  cpxCampaignId     String?
  cpxSessionsCompleted Int   @default(0)
  status            String   @default("PENDING")
  creatorEmail      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  surveyCompletions SurveyCompletion[]
  @@index([status])
  @@index([createdAt])
  @@index([cpxCampaignId])
}

model SurveyCompletion {
  id             String   @id @default(cuid())
  fundraiserId   String
  fundraiser     Fundraiser @relation(fields: [fundraiserId], references: [id], onDelete: Cascade)
  provider       String
  rewardAmount   Float
  cpxSessionId   String?  @unique
  cpxUserId      String?
  cpxOfferId     String?
  cpxPayout      Float?
  completedAt    DateTime @default(now())
  @@index([fundraiserId])
  @@index([cpxSessionId])
  @@index([provider])
}
